<section class="ref-home ref-hero">
  <div class="ref-hero__media">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '750,1100,1600,2200,2400', alt: section.settings.heading }}
    {% endif %}
  </div>
  <div class="ref-hero__shade"></div>
  <div class="ref-hero__inner">
    <h1 class="ref-hero__title">{{ section.settings.heading }}</h1>
    <p class="ref-hero__copy">{{ section.settings.copy }}</p>
  </div>
</section>
{% schema %}
{"name":"Reference hero","settings":[{"type":"image_picker","id":"image","label":"Hero image"},{"type":"text","id":"heading","label":"Heading","default":"Your body is done. Your mind isn’t."},{"type":"text","id":"copy","label":"Subheading","default":"A calmer wind-down for city nights."}],"presets":[{"name":"Reference hero"}]}
{% endschema %}
