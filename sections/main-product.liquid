<section class="product-main"><div class="page-width product-grid"><div class="product-media">{% if product.featured_image %}{{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: product.title }}{% else %}<div class="product-pack" style="position:relative;transform:rotate(5deg)"><div class="pack-mark">KODO</div><div class="pack-product">Night<br>Pack</div><div class="pack-detail">MAGNESIUM · L-THEANINE · ASHWAGANDHA<br>30 DAILY SERVINGS</div></div>{% endif %}</div><div><p class="product-label">KODO · Night routine</p><h1 class="product-title">{{ product.title }}</h1><p class="product-subtitle">For nights when your body is tired, but your mind won’t switch off.</p><p class="product-price">{{ product.selected_or_first_available_variant.price | money }}</p>{% form 'product', product, class: 'product-form' %}{% if product.variants.size > 1 %}<label for="VariantSelect">Choose an option</label><select id="VariantSelect" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>{{ variant.title }} — {{ variant.price | money }}</option>{% endfor %}</select>{% else %}<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">{% endif %}<button class="button" type="submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>{% if product.selected_or_first_available_variant.available %}Add to bag{% else %}Sold out{% endif %}</button>{% endform %}<div class="product-usp"><div>✓ No melatonin</div><div>✓ Full doses, nothing hidden</div><div>✓ Manufactured in Taiwan in a GMP-certified facility</div></div><div class="accordions"><details class="accordion" open><summary>What’s inside</summary><div class="accordion-content"><p>Four capsules daily: Magnesium Bisglycinate &amp; Citrate Chelate (120mg elemental magnesium), L-Theanine (200mg), and Ashwagandha Extract (Withania somnifera root) (250mg).</p></div></details><details class="accordion"><summary>How to take it</summary><div class="accordion-content"><p>Take four capsules daily, around 30–60 minutes before bed. Build it into the same wind-down routine each evening.</p></div></details><details class="accordion"><summary>Quality standards</summary><div class="accordion-content"><p>No proprietary blends. Full ingredient labelling. Manufactured in Taiwan in a GMP-certified facility. Confirm final label and testing documentation before publishing.</p></div></details></div></div></div></section>{% schema %}{"name":"Main product","settings":[]}{% endschema %}