<section class="hero">
  <div class="page-width hero-grid">
    <div>
      <p class="eyebrow">Night Pack · Daily sleep support</p>
      <h1 class="display">{{ section.settings.heading }}</h1>
      <p class="hero-copy">{{ section.settings.copy }}</p>
      <div class="hero-actions">
        <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="button button--light" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="hero-visual" aria-label="Night Pack product visual">
      <div class="orb"></div>
      <div class="product-pack">
        <div class="pack-mark">KODO</div>
        <div class="pack-product">Night<br>Pack</div>
        <div class="pack-detail">MAGNESIUM · L-THEANINE · ASHWAGANDHA<br>30 DAILY SERVINGS</div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{"name":"Night Pack hero","settings":[{"type":"text","id":"heading","label":"Heading","default":"Your body is done. Your mind isn’t."},{"type":"textarea","id":"copy","label":"Copy","default":"Night Pack helps you wind down, stay down, and wake up clear — without melatonin."},{"type":"text","id":"primary_label","label":"Primary CTA","default":"Shop Night Pack"},{"type":"url","id":"primary_link","label":"Primary CTA link"},{"type":"text","id":"secondary_label","label":"Secondary CTA","default":"The Science"},{"type":"url","id":"secondary_link","label":"Secondary CTA link"}],"presets":[{"name":"Night Pack hero"}]}
{% endschema %}
